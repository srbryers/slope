{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh explore",
            "timeout": 10,
            "statusMessage": "SLOPE: Suggest checking codebase index before deep exploration"
          }
        ],
        "matcher": "Read|Glob|Grep|Edit|Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh hazard",
            "timeout": 10,
            "statusMessage": "SLOPE: Warn about known issues in file areas being edited"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh scope-drift",
            "timeout": 10,
            "statusMessage": "SLOPE: Warn when editing files outside claimed ticket scope"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh stale-flows",
            "timeout": 10,
            "statusMessage": "SLOPE: Warn when editing files belonging to a stale flow definition"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh claim-required",
            "timeout": 10,
            "statusMessage": "SLOPE: Warn when editing code without an active sprint claim"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh subagent-gate",
            "timeout": 10,
            "statusMessage": "SLOPE: Enforce model selection on Explore/Plan subagents"
          }
        ],
        "matcher": "Agent"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh workflow-gate",
            "timeout": 10,
            "statusMessage": "SLOPE: Block ExitPlanMode until review rounds are complete"
          }
        ],
        "matcher": "ExitPlanMode"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh version-check",
            "timeout": 10,
            "statusMessage": "SLOPE: Block push to main when package versions have not been bumped"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh branch-before-commit",
            "timeout": 10,
            "statusMessage": "SLOPE: Block git commit on main/master — create a feature branch first"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh sprint-completion",
            "timeout": 10,
            "statusMessage": "SLOPE: Block PR creation when sprint gates are incomplete"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh worktree-merge",
            "timeout": 10,
            "statusMessage": "SLOPE: Block gh pr merge --delete-branch in worktrees (causes false failure)"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh worktree-self-remove",
            "timeout": 10,
            "statusMessage": "SLOPE: Block git worktree remove when targeting own cwd"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh phase-boundary",
            "timeout": 10,
            "statusMessage": "SLOPE: Block starting sprint in new phase if previous phase cleanup incomplete"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh worktree-check",
            "timeout": 10,
            "statusMessage": "SLOPE: Block concurrent sessions without worktree isolation"
          }
        ],
        "matcher": "Read|Glob|Grep|Edit|Write|Bash"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh commit-nudge",
            "timeout": 10,
            "statusMessage": "SLOPE: Nudge to commit/push after prolonged editing"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh review-tier",
            "timeout": 10,
            "statusMessage": "SLOPE: Suggest plan review with specialist reviewers after plan file write"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh push-nudge",
            "timeout": 10,
            "statusMessage": "SLOPE: Nudge to push after git commits when unpushed count or time is high"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh pr-review",
            "timeout": 10,
            "statusMessage": "SLOPE: Prompt for review workflow after PR creation"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh sprint-completion",
            "timeout": 10,
            "statusMessage": "SLOPE: Auto-detect test pass and mark gate complete"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh post-push",
            "timeout": 10,
            "statusMessage": "SLOPE: Suggest next workflow step after git push"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh transcript",
            "timeout": 10,
            "statusMessage": "SLOPE: Append tool call metadata to session transcript"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh session-briefing",
            "timeout": 10,
            "statusMessage": "SLOPE: Inject sprint context on first tool call of session"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh compaction",
            "timeout": 10,
            "statusMessage": "SLOPE: Extract events before context compaction"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh stop-check",
            "timeout": 10,
            "statusMessage": "SLOPE: Check for uncommitted/unpushed work before session end"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh next-action",
            "timeout": 10,
            "statusMessage": "SLOPE: Suggest next actions before session end"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh sprint-completion",
            "timeout": 10,
            "statusMessage": "SLOPE: Block session end when sprint gates are incomplete"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/slope-guard.sh review-stale",
            "timeout": 10,
            "statusMessage": "SLOPE: Warn about scored sprints with missing reviews at session end"
          }
        ]
      }
    ]
  }
}
