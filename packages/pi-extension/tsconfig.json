{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@slope-dev/slope": ["../../dist/index.d.ts"],
      "@slope-dev/slope/*": ["../../dist/*.d.ts"]
    }
  },
  "include": ["src"]
}
